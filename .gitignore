/target
/data
.claude/
*.db
*.db-wal
*.db-shm
Cargo.lock
# Local environment overrides (API keys, etc.) — never commit.
.env
# Generated artifacts
journals*/
/demo-output/*.md
/demo-output/*.log
/demo-output/*-dashboard.txt
/demo-output/sweep-summary.json
!/demo-output/.gitkeep
# Preserve the curated sweep reports so they ship in the public repo.
# The glob matches MODEL-SWEEP-REPORT.md and all versioned successors
# (MODEL-SWEEP-REPORT-v2.md, ...).
!/demo-output/MODEL-SWEEP-REPORT*.md
# Also preserve the machine-readable quality analyses so the repo ships
# with something a README badge generator can pull from.
!/demo-output/reflector-quality*.txt
!/demo-output/reflector-quality*.json
# Versioned analyzer outputs (bite-rate matrices, conformance
# matrices, …) ship alongside the curated reports so the published
# numbers are reproducible from the repo state.
!/demo-output/v*-bite-rate-matrix.md
!/demo-output/v*-cross-impl-matrix.md
