/target
/data
.claude/
docs/superpowers/
docs/plans/
evals/escape/results/*.jsonl
evals/escape/results/*.json
evals/escape/results/*.strace
# Any sub-directory under results/ (sweep/, sweep_n200/, sweep_<future>/, ...)
# holds per-trial transcripts that include exploit content; never commit.
# See evals/escape/PUBLISHABILITY.md for the policy.
evals/escape/results/*/
!evals/escape/results/.gitkeep
evals/escape/.venv/
evals/escape/.pytest_cache/
evals/escape/**/__pycache__/
evals/escape/**/*.egg-info/
CLAUDE.md
AGENTS.md
GEMINI.md
COPILOT.md
CURSOR.md
*.db
*.db-wal
*.db-shm
Cargo.lock
# Local environment overrides (API keys, etc.) — never commit.
.env
# Generated artifacts
journals*/
/demo-output/*.md
/demo-output/*.log
/demo-output/*-dashboard.txt
/demo-output/sweep-summary.json
!/demo-output/.gitkeep
# Preserve the curated sweep reports so they ship in the public repo.
# The glob matches MODEL-SWEEP-REPORT.md and all versioned successors
# (MODEL-SWEEP-REPORT-v2.md, ...).
!/demo-output/MODEL-SWEEP-REPORT*.md
# Also preserve the machine-readable quality analyses so the repo ships
# with something a README badge generator can pull from.
!/demo-output/reflector-quality*.txt
!/demo-output/reflector-quality*.json
# Versioned analyzer outputs (bite-rate matrices, conformance
# matrices, ablation matrices, …) ship alongside the curated reports
# so the published numbers are reproducible from the repo state.
!/demo-output/v*-bite-rate-matrix.md
!/demo-output/v*-cross-impl-matrix.md
!/demo-output/v*-ablation-matrix.md
# Per-trial Karpathy-loop transcripts kept out of the public repo for
# training-corpus-risk reasons. The curated report.md inside each run dir
# stays tracked; the raw per-iteration JSONs do not. See
# evals/escape/PUBLISHABILITY.md for the policy.
demo-output/**/journals/
